---
const links = [
  { href: "#", label: "GitHub" },
  { href: "#", label: "Discord" },
  { href: "#", label: "Twitter" },
];
---

<section id="contact" class="section-soft pb-24">
  <div class="container-soft">
    <div
      class="glass-card relative overflow-hidden px-6 py-12 text-center md:px-12 md:py-16"
    >
      <div
        class="absolute -left-20 top-4 h-52 w-52 rounded-full bg-aqua-soft/50 blur-3xl"
        aria-hidden="true"
      >
      </div>
      <div
        class="absolute -right-16 bottom-0 h-60 w-60 rounded-full bg-lavender-soft/44 blur-3xl"
        aria-hidden="true"
      >
      </div>
      <div
        class="sparkle left-[18%] top-[22%] text-mint-soft"
        aria-hidden="true"
      >
      </div>
      <div
        class="sparkle right-[18%] top-[28%] text-aqua-soft"
        aria-hidden="true"
      >
      </div>

      <div class="relative mx-auto max-w-3xl">
        <p class="eyebrow reveal">Let’s Build</p>
        <h2
          class="reveal mt-5 font-heading text-4xl font-bold leading-tight text-ink md:text-5xl"
        >
          Have a Roblox system, website, or magical UI idea?
        </h2>
        <p class="reveal mx-auto mt-5 max-w-2xl text-lg leading-8 text-muted">
          I’m open to portfolio collaborations, game prototypes, web projects,
          and developer-focused systems.
        </p>
        <div class="reveal mt-8 flex flex-wrap justify-center gap-4">
          <a class="slime-button" href="#projects">Start a Project</a>
          {
            links.map((link) => (
              <a class="slime-button secondary" href={link.href}>
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
