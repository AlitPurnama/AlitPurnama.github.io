---
interface Props {
  title?: string;
}

const { title = "Project note" } = Astro.props;
---

<aside
  class="my-7 rounded-[1.5rem] border-2 border-white/70 bg-gradient-to-br from-aqua-soft/36 via-white/62 to-lavender-soft/34 p-5 shadow-[0_18px_48px_rgba(111,80,146,0.10)]"
>
  <p class="font-mono text-xs font-semibold text-lavender">{title}</p>
  <div class="mt-2 text-muted">
    <slot />
  </div>
</aside>
