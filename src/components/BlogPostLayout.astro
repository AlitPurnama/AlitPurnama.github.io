---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BlogMeta from "./BlogMeta.astro";
import BlogTagList from "./BlogTagList.astro";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const {
  title,
  description,
  publishDate,
  updatedDate,
  category,
  tags,
  coverImage,
  coverAlt,
} = post.data;
---

<article class="container-soft py-14 md:py-20">
  <a
    href="/blog"
    class="mb-8 inline-flex rounded-full bg-white/58 px-4 py-2 font-mono text-xs font-semibold text-aqua shadow-[0_12px_30px_rgba(30,102,122,0.10)] transition hover:bg-aqua-soft/60"
  >
    ← Back to blog
  </a>

  <header class="mx-auto max-w-[820px] text-center">
    <BlogMeta
      category={category}
      publishDate={publishDate}
      updatedDate={updatedDate}
    />
    <h1
      class="mt-5 font-heading text-[clamp(2.35rem,5vw,4.8rem)] font-bold leading-[1.06] text-ink"
    >
      {title}
    </h1>
    <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-muted">
      {description}
    </p>
    <div class="mt-7 flex justify-center">
      <BlogTagList tags={tags} />
    </div>
  </header>

  {
    coverImage && (
      <div class="glass-card mx-auto mt-10 max-w-[960px] overflow-hidden p-3">
        <Image
          src={coverImage}
          alt={coverAlt ?? ""}
          class="aspect-[16/9] w-full rounded-[1.4rem] object-cover"
          width={1280}
          height={720}
        />
      </div>
    )
  }

  <div class="glass-card mx-auto mt-10 max-w-[820px] p-6 md:p-10">
    <div class="blog-prose">
      <slot />
    </div>
  </div>
</article>
