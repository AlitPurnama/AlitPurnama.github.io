---
const highlights = [
  "Roblox game development",
  "Luau scripting",
  "UI systems",
  "Gameplay systems",
  "Modern web development",
];
---

<section id="about" class="section-soft">
  <div
    class="container-soft grid items-center gap-8 lg:grid-cols-[0.82fr_1.18fr]"
  >
    <div class="section-heading text-left lg:mx-0">
      <p class="eyebrow reveal">About Me</p>
      <h2
        class="reveal mt-5 font-heading text-4xl font-bold leading-tight text-ink md:text-5xl"
      >
        Soft visuals, solid systems, playful engineering.
      </h2>
    </div>

    <div class="reveal glass-card p-7 md:p-9">
      <p class="text-lg leading-8 text-muted">
        I’m an Informatics Engineering student focused on building practical
        interactive systems. My work mixes Roblox game development, Luau
        scripting, responsive UI systems, gameplay systems, and web development
        for tools and portfolio experiences.
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        {
          highlights.map((item, index) => (
            <span
              class:list={[
                "tech-chip",
                index % 3 === 1 && "lavender",
                index % 3 === 2 && "mint",
              ]}
            >
              {item}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>
