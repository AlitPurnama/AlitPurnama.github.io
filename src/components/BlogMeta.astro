---
interface Props {
  category: string;
  publishDate: Date;
  updatedDate?: Date;
}

const { category, publishDate, updatedDate } = Astro.props;
const dateFormatter = new Intl.DateTimeFormat("en", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
---

<div
  class="flex flex-wrap items-center gap-3 font-mono text-xs font-semibold text-muted"
>
  <span class="rounded-full bg-aqua-soft/70 px-3 py-1 text-aqua">
    {category}
  </span>
  <time datetime={publishDate.toISOString()}>
    {dateFormatter.format(publishDate)}
  </time>
  {
    updatedDate && (
      <span>
        Updated{" "}
        <time datetime={updatedDate.toISOString()}>
          {dateFormatter.format(updatedDate)}
        </time>
      </span>
    )
  }
</div>
